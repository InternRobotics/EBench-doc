---
const isZh = Astro.locals.starlightRoute.locale === 'zh-cn';
const labels = {
	light: isZh ? '浅色' : 'Light',
	dark: isZh ? '深色' : 'Dark',
	auto: isZh ? '自动' : 'Auto',
};
---

<theme-toggle class="theme-toggle" data-light={labels.light} data-dark={labels.dark} data-auto={labels.auto}>
	<button class="theme-toggle__button" data-theme="light" aria-label={labels.light} type="button">
		<svg viewBox="0 0 20 20" fill="none">
			<circle cx="10" cy="10" r="3.1" stroke="currentColor" stroke-width="1.6" />
			<path d="M10 2.7v2.1M10 15.2v2.1M4.8 4.8l1.5 1.5M13.7 13.7l1.5 1.5M2.7 10h2.1M15.2 10h2.1M4.8 15.2l1.5-1.5M13.7 6.3l1.5-1.5" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" />
		</svg>
	</button>
	<button class="theme-toggle__button" data-theme="dark" aria-label={labels.dark} type="button">
		<svg viewBox="0 0 20 20" fill="none">
			<path d="M13.8 14.6A6.3 6.3 0 0 1 5.4 6.2a6.6 6.6 0 1 0 8.4 8.4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
		</svg>
	</button>
	<button class="theme-toggle__button" data-theme="auto" aria-label={labels.auto} type="button">
		<svg viewBox="0 0 20 20" fill="none">
			<rect x="3.5" y="4.4" width="13" height="9" rx="1.9" stroke="currentColor" stroke-width="1.45" />
			<path d="M7.4 15.6h5.2M10 13.7v1.9" stroke="currentColor" stroke-width="1.45" stroke-linecap="round" />
		</svg>
	</button>
</theme-toggle>

<script>
	type Theme = 'auto' | 'dark' | 'light';

	const storageKey = 'starlight-theme';

	const parseTheme = (theme: unknown): Theme =>
		theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';

	const getPreferredColorScheme = (): Theme =>
		matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

	const loadTheme = (): Theme =>
		parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

	const storeTheme = (theme: Theme) => {
		try {
			localStorage.setItem(storageKey, theme === 'auto' ? '' : theme);
		} catch {}
	};

	const syncButtons = (host: ParentNode, theme: Theme) => {
		host.querySelectorAll<HTMLButtonElement>('button[data-theme]').forEach((button) => {
			button.setAttribute('aria-pressed', String(button.dataset.theme === theme));
		});
	};

	const applyTheme = (theme: Theme) => {
		document.documentElement.dataset.theme = theme === 'auto' ? getPreferredColorScheme() : theme;
		storeTheme(theme);
		window.StarlightThemeProvider?.updatePickers(theme);
		document.querySelectorAll('theme-toggle').forEach((host) => syncButtons(host, theme));
	};

	if (!customElements.get('theme-toggle')) {
		matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
			if (loadTheme() === 'auto') applyTheme('auto');
		});

		class ThemeToggle extends HTMLElement {
			connectedCallback() {
				if (this.dataset.bound === 'true') return;
				this.dataset.bound = 'true';

				const sync = () => {
					const current = loadTheme();
					document.documentElement.dataset.theme =
						current === 'auto' ? getPreferredColorScheme() : current;
					syncButtons(this, current);
				};

				sync();

				this.querySelectorAll<HTMLButtonElement>('button[data-theme]').forEach((button) => {
					button.addEventListener('click', () => {
						applyTheme(parseTheme(button.dataset.theme));
					});
				});

				window.addEventListener('pageshow', sync);
			}
		}

		customElements.define('theme-toggle', ThemeToggle);
	}
</script>

<style>
	@layer starlight.core {
		.theme-toggle {
			display: inline-flex;
			align-items: center;
			gap: 0.16rem;
			padding: 0.22rem;
			border: 1px solid var(--ebench-line-soft);
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.9);
			box-shadow: 0 12px 26px rgba(34, 20, 20, 0.1);
		}

		.theme-toggle__button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 1.95rem;
			height: 1.95rem;
			padding: 0;
			border: 0;
			border-radius: 999px;
			background: transparent;
			color: var(--sl-color-gray-3);
			cursor: pointer;
			transition:
				background-color 160ms ease,
				color 160ms ease,
				transform 160ms ease;
		}

		.theme-toggle__button svg {
			display: block;
			width: 1rem;
			height: 1rem;
		}

		.theme-toggle__button:hover {
			background: var(--ebench-hover-bg);
			color: var(--sl-color-gray-1);
		}

		.theme-toggle__button[aria-pressed='true'] {
			background: var(--ebench-highlight-bg);
			color: var(--ebench-highlight-text);
		}

		:root:not([data-theme='light']) .theme-toggle {
			background: var(--ebench-surface-raised);
			box-shadow: none;
		}
	}
</style>
