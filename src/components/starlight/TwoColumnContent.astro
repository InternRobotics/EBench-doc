---
const hasToc = Boolean(Astro.locals.starlightRoute.toc);
---

<div class:list={['doc-columns', { 'has-toc': hasToc }]}>
	{hasToc && <aside class="right-sidebar-container"><slot name="right-sidebar" /></aside>}
	<div class="main-pane"><slot /></div>
</div>

<style>
	@layer starlight.core {
		.doc-columns {
			display: flex;
			flex-direction: column;
			min-height: 0;
		}

		.main-pane {
			flex: 1 1 auto;
			min-width: 0;
			min-height: 0;
		}

		.main-pane :global([id]) {
			scroll-margin-top: calc(var(--sl-nav-height) + 1rem);
		}

		@media (min-width: 50rem) {
			.doc-columns {
				height: 100%;
				min-height: 0;
			}

			.main-pane {
				order: 1;
				display: flex;
				flex-direction: column;
			}

			.main-pane :global(main) {
				min-height: 100%;
				scroll-padding-top: 1rem;
			}
		}

		@media (min-width: 72rem) {
			.doc-columns.has-toc {
				display: grid;
				grid-template-columns: minmax(0, 1fr) var(--ebench-toc-width, 12rem);
				grid-template-rows: minmax(0, 1fr);
				column-gap: 1.8rem;
				align-items: stretch;
			}

			.right-sidebar-container {
				order: 2;
				min-height: 0;
			}
		}
	}
</style>
