---

<span class:list={['nav-icon', className]} aria-hidden="true">
	<svg viewBox="0 0 20 20" fill="none" set:html={iconMarkup[name] || iconMarkup.document}></svg>
</span>

<style>
	.nav-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1rem;
		height: 1rem;
		color: currentColor;
		flex-shrink: 0;
	}

	svg {
		display: block;
		width: 100%;
		height: 100%;
	}
</style>
