---
import config from 'virtual:starlight/user-config';

const currentLocale = Astro.locals.starlightRoute.locale;
const localeEntries = Object.entries(config.locales ?? {});
const nonRootLocales = localeEntries.map(([code]) => code).filter((code) => code !== 'root');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const stripBase = (pathname: string) => {
	if (!base) return pathname;
	if (pathname === base) return '/';
	if (pathname.startsWith(`${base}/`)) return pathname.slice(base.length);
	return pathname;
};

const stripLocalePrefix = (pathname: string) => {
	for (const code of nonRootLocales) {
		if (pathname === `/${code}` || pathname === `/${code}/`) return '/';
		if (pathname.startsWith(`/${code}/`)) return pathname.slice(code.length + 1);
	}
	return pathname || '/';
};

const ensureTrailingSlash = (pathname: string) => {
	if (pathname === '/') return pathname;
	return pathname.endsWith('/') ? pathname : `${pathname}/`;
};

const basePathname = ensureTrailingSlash(stripLocalePrefix(stripBase(Astro.url.pathname)));

const locales = localeEntries.map(([code, locale]) => ({
	code,
	label: locale!.label,
	href:
		code === 'root'
			? `${base}${basePathname}`
			: `${base}/${code}${basePathname === '/' ? '/' : basePathname}`,
	current: code === currentLocale,
}));

const currentLabel = locales.find((locale) => locale.current)?.label ?? 'English';
const accessibleLabel = Astro.locals.t('languageSelect.accessibleLabel');
---

<details class="locale-switcher">
	<summary aria-label={accessibleLabel}>
		<span class="locale-switcher__icon" aria-hidden="true">
			<svg viewBox="0 0 20 20" fill="none">
				<circle cx="10" cy="10" r="6.4" stroke="currentColor" stroke-width="1.5" />
				<path d="M3.9 10h12.2M10 3.8c1.7 1.8 2.5 3.9 2.5 6.2S11.7 14.4 10 16.2M10 3.8C8.3 5.6 7.5 7.7 7.5 10s.8 4.4 2.5 6.2" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" />
			</svg>
		</span>
		<span class="locale-switcher__label">{currentLabel}</span>
		<span class="locale-switcher__caret" aria-hidden="true">
			<svg viewBox="0 0 16 16" fill="none">
				<path d="m4.5 6 3.5 4 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</span>
	</summary>
	<div class="locale-switcher__menu">
		{
			locales.map((locale) => (
				<a class:list={['locale-switcher__option', { current: locale.current }]} href={locale.href}>
					{locale.label}
				</a>
			))
		}
	</div>
</details>

<style>
	@layer starlight.core {
		.locale-switcher {
			position: relative;
			display: inline-flex;
		}

		.locale-switcher summary {
			display: inline-flex;
			align-items: center;
			gap: 0.38rem;
			height: 2.08rem;
			padding: 0 0.72rem;
			border: 1px solid rgba(255, 255, 255, 0.28);
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.1);
			color: rgba(255, 255, 255, 0.96);
			font-size: 0.8rem;
			font-weight: 700;
			list-style: none;
			cursor: pointer;
			backdrop-filter: blur(10px);
			transition:
				background-color 160ms ease,
				border-color 160ms ease,
				transform 160ms ease;
		}

		.locale-switcher summary::-webkit-details-marker,
		.locale-switcher summary::marker {
			display: none;
		}

		.locale-switcher summary:hover {
			background: rgba(255, 255, 255, 0.16);
			border-color: rgba(255, 255, 255, 0.44);
		}

		.locale-switcher[open] summary {
			background: rgba(255, 255, 255, 0.18);
			border-color: rgba(255, 255, 255, 0.48);
		}

		.locale-switcher[open] {
			z-index: 12;
		}

		.locale-switcher__icon,
		.locale-switcher__caret {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 0.92rem;
			height: 0.92rem;
			flex-shrink: 0;
		}

		.locale-switcher__icon svg,
		.locale-switcher__caret svg {
			display: block;
			width: 100%;
			height: 100%;
		}

		.locale-switcher__caret svg {
			transition: transform 180ms ease;
		}

		.locale-switcher[open] .locale-switcher__caret svg {
			transform: rotate(180deg);
		}

		.locale-switcher__menu {
			position: absolute;
			inset: calc(100% + 0.38rem) auto auto 50%;
			transform: translateX(-50%);
			display: grid;
			gap: 0.22rem;
			width: max-content;
			min-width: max(100%, 8.25rem);
			padding: 0.45rem;
			border: 1px solid var(--ebench-line-soft);
			border-radius: 0.9rem;
			background: rgba(255, 255, 255, 0.94);
			box-shadow: 0 18px 36px rgba(34, 20, 20, 0.12);
		}

		.locale-switcher__option {
			display: block;
			padding: 0.48rem 0.65rem;
			border-radius: 0.66rem;
			color: var(--sl-color-gray-2);
			font-size: 0.84rem;
			font-weight: 600;
			text-decoration: none;
		}

		.locale-switcher__option:hover {
			background: var(--ebench-hover-bg);
			color: var(--sl-color-gray-1);
		}

		.locale-switcher__option.current {
			background: var(--ebench-highlight-bg);
			color: var(--ebench-highlight-text);
		}

		:root:not([data-theme='light']) .locale-switcher__menu {
			background: var(--ebench-surface-raised);
			box-shadow: none;
		}
	}
</style>
